{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"private_outputs":true,"provenance":[],"authorship_tag":"ABX9TyMpGlDxAA+BvN3F+Sg8jT1B"},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"}},"cells":[{"cell_type":"markdown","source":["%%html\n","<!DOCTYPE html>\n","<html lang=\"pt-BR\">\n","<head>\n","    <meta charset=\"UTF-8\">\n","    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n","    <title>Animação com Canvas</title>\n","    <style>\n","      body { display: flex; justify-content: center; align-items: center; height: 100vh; margin: 0; background-color: #f0f0f0; }\n","        canvas { background-color: #fff; }\n","    </style>\n","</head>\n","<body>\n","    <canvas id=\"meuCanvas\" width=\"800\" height=\"600\"></canvas>\n","    <script>\n","        const canvas = document.getElementById('meuCanvas');\n","const ctx = canvas.getContext('2d');\n","\n","const circulos = [];\n","const numCirculos = 40px;\n","for (let i = 0; i < numCirculos; i++) {\n","    circulos.push({\n","        x: Math.random() * canvas.width,\n","        y: Math.random() * canvas.height,\n","        raio: 20,\n","        dx: (Math.random() - 0.5) * 2,\n","        dy: (Math.random() - 0.5) * 2,\n","        cor: `hsl(${Math.random() * 360}, 100%, 50%)`\n","    });\n","}\n","\n","function desenhar() {\n","    ctx.clearRect(0, 0, canvas.width, canvas.height);\n","    for (let i = 0; i < circulos.length; i++) {\n","        const c = circulos[i];\n","        ctx.beginPath();\n","        ctx.arc(c.x, c.y, c.raio, 0, Math.PI * 2);\n","        ctx.fillStyle = c.cor;\n","        ctx.fill();\n","        ctx.closePath();\n","\n","        c.x += c.dx;\n","        c.y += c.dy;\n","\n","        if (c.x + c.raio > canvas.width || c.x - c.raio < 0) {\n","            c.dx = -c.dx;\n","        }\n","        if (c.y + c.raio > canvas.height || c.y - c.raio < 0) {\n","            c.dy = -c.dy;\n","        }\n","\n","        c.cor = `hsl(${Math.random() * 360}, 100%, 50%)`;\n","    }\n","}\n","\n","function animar() {\n","    requestAnimationFrame(animar);\n","    desenhar();\n","}\n","\n","animar();\n","\n","    </script>\n","</body>\n","</html>\n"],"metadata":{"id":"Uv5CxpBtXTGH"}},{"cell_type":"code","source":[],"metadata":{"id":"qh0XnSpVbio6"},"execution_count":null,"outputs":[]}]}